<Project>
    <PropertyGroup Label="Source generator settings">
        <IsSourceGeneratorProject>true</IsSourceGeneratorProject>
        <TargetFramework>netstandard2.0</TargetFramework>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <LangVersion>14</LangVersion>
        <PackageScribanIncludeSource>true</PackageScribanIncludeSource>
        <PolySharpIncludeRuntimeSupportedAttributes>true</PolySharpIncludeRuntimeSupportedAttributes>
        <IncludeSymbols>false</IncludeSymbols>
        <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
        <IsRoslynComponent>true</IsRoslynComponent>
        <GetTargetPathDependsOn>$(GetTargetPathDependsOn);GetDependencyTargetPaths</GetTargetPathDependsOn>
    </PropertyGroup>

    <ItemGroup Label="Source generation references">
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp"/>
    </ItemGroup>

    <ItemGroup Label="Scriban dependencies">
        <PackageReference Include="Scriban" Pack="true" IncludeAssets="Build" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.CSharp"/>
        <PackageReference Include="System.Threading.Tasks.Extensions"/>
        <PackageReference Include="PolySharp" PrivateAssets="all" IncludeAssets="runtime; build; native; contentfiles; analyzers"/>
    </ItemGroup>

    <ItemGroup Label="Humanizer dependencies">
        <PackageReference Include="Humanizer.Core" GeneratePathProperty="true" PrivateAssets="all"/>
    </ItemGroup>

    <ItemGroup Label="Source generation settings">
        <None Include="$(OutputPath)\$(TargetName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false"/>
        <None Include="$(PKGHumanizer_Core)\lib\netstandard2.0\*.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
        <Compile Include="..\SourceGenerators.Shared\SourceGenerationHelper.cs"/>
        <Compile Include="..\SourceGenerators.Shared\RequiredMemberAttribute.cs"/>
        <Compile Include="..\SourceGenerators.Shared\SetsRequiredMembersAttribute.cs"/>
    </ItemGroup>

    <Target Name="GetDependencyTargetPaths">
        <ItemGroup>
            <TargetPathWithTargetPlatformMoniker Include="$(PKGHumanizer_Core)\lib\netstandard2.0\*.dll" IncludeRuntimeDependency="false" />
        </ItemGroup>
    </Target>
</Project>
